# Static demo mode does not require environment variables.

# Supabase, used after migration from localStorage.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Server-side only. Never expose this in browser code.
SUPABASE_SERVICE_ROLE_KEY=

# Server-side only. Choose "openai" or "qwen".
AI_PROVIDER=openai

# Server-side only. OpenAI option.
OPENAI_API_KEY=
OPENAI_ANALYSIS_MODEL=gpt-5-mini

# Server-side only. Qwen / Alibaba Cloud Model Studio option.
DASHSCOPE_API_KEY=
QWEN_ANALYSIS_MODEL=qwen-vl-max
