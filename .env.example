# Static demo mode does not require environment variables.

# Supabase, used after migration from localStorage.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Server-side only. Never expose this in browser code.
SUPABASE_SERVICE_ROLE_KEY=

# Server-side only. Used by future AI endpoints.
OPENAI_API_KEY=
OPENAI_ANALYSIS_MODEL=gpt-5-mini
